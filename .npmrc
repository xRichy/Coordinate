# pnpm: hoist Prisma generated client so @prisma/client can find .prisma/client
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=.prisma
# Hoist Node type defs to the root so every package's tsc resolves them — the
# modules recompile core/database source (via path aliases) which use process/node:*.
public-hoist-pattern[]=@types/node
# Don't prompt before purging node_modules when hoist config changes (non-interactive / CI).
confirm-modules-purge=false
