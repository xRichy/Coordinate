# Copy to .env.local and fill in the values.
#
# Single-domain setup: the app runs on one origin (localhost:3000 in dev,
# coordinate.app in prod). No cross-subdomain cookies or wildcard origins needed.

# ── Database ────────────────────────────────────────────────────────────────
# See packages/database/.env.example for setup instructions.
DATABASE_URL="postgresql://coordinate_app:coordinate@localhost:5433/coordinate_dev"
DIRECT_URL="postgresql://coordinate:coordinate@localhost:5433/coordinate_dev"

# ── Better-Auth ─────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me"
# URL of this app (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# ── OAuth (optional) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ── Observability (optional — safe to leave empty) ──────────────────────────
# Sentry
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oYYY.ingest.sentry.io/ZZZ"
# SENTRY_ORG="your-sentry-org-slug"
# SENTRY_PROJECT="coordinate"
# SENTRY_AUTH_TOKEN=""

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# POSTHOG_API_KEY="phc_xxx"
# POSTHOG_HOST="https://eu.i.posthog.com"
