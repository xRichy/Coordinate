{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@coordinate/ui": ["../../packages/ui/src/index.ts"],
      "@coordinate/core": ["../../packages/core/src/index.ts"],
      "@coordinate/database": ["../../packages/database/src/index.ts"],
      "@coordinate/api": ["../../packages/api/src/index.ts"],
      "@coordinate/config": ["../../packages/config"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
