# Postgres locale via Docker
#
# Avvia il DB con: docker compose up -d
#
# DATABASE_URL  usato da Prisma a runtime
# DIRECT_URL    usato da Prisma Migrate (può essere uguale in locale)
#
# Copia questo file in `apps/web/.env` e lascia i valori invariati se usi Docker Compose.

DATABASE_URL="postgresql://coordinate:coordinate@localhost:5432/coordinate_dev"
DIRECT_URL="postgresql://coordinate:coordinate@localhost:5432/coordinate_dev"
