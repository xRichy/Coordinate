# Postgres locale via Docker
#
# Avvia il DB con: docker compose up -d
#
# Nota: la porta host è 5433 (non 5432) perché macOS ha PostgreSQL locale
# già in ascolto su 5432. Il container interno usa sempre 5432.
#
# DATABASE_URL  usato da Prisma a runtime
# DIRECT_URL    usato da Prisma Migrate (può essere uguale in locale)

DATABASE_URL="postgresql://coordinate:coordinate@localhost:5433/coordinate_dev"
DIRECT_URL="postgresql://coordinate:coordinate@localhost:5433/coordinate_dev"
