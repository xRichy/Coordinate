{
  "name": "@coordinate/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:seed:mich": "tsx prisma/seed-mich.ts",
    "db:seed:e2e": "tsx prisma/seed-e2e.ts",
    "db:provision": "tsx prisma/provision-tenant.ts",
    "db:reset-password": "tsx prisma/reset-password.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
