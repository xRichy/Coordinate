generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TenantPlan {
  starter
  pro
  business
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

// ── crm-contacts ──────────────────────────────────────────────────────────────

enum ContactType {
  person
  company
}

enum ContactStatus {
  active
  inactive
  customer
}

enum DealStatus {
  open
  won
  lost
}

// ─── Core multi-tenant models ─────────────────────────────────────────────────

model Tenant {
  id             String       @id @default(cuid())
  slug           String       @unique
  name           String
  plan           TenantPlan   @default(starter)
  status         TenantStatus @default(active)
  enabledModules String[]     @default(["dashboard", "crm-contacts", "crm-pipeline", "activities", "warehouse", "calendar"])
  maxSeats       Int          @default(2) // account inclusi (owner + 1); slot extra sbloccati dalla super-admin dopo pagamento
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships    Membership[]
  settings       TenantSetting[]
  auditLogs      AuditLog[]
  contacts       Contact[]
  pipelineStages PipelineStage[]
  leads          Lead[]
  deals          Deal[]
  activities     Activity[]
  products       Product[]
  stockMovements StockMovement[]
  tags           Tag[]
  timelineEvents TimelineEvent[]
  notifications  Notification[]
  quotes         Quote[]
  quoteLines     QuoteLine[]
  sales          Sale[]
  workOrders     WorkOrder[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Two-factor extension (added by twoFactor plugin)
  twoFactorEnabled Boolean?

  sessions      Session[]
  accounts      Account[]
  memberships   Membership[]
  auditLogs     AuditLog[]
  baMembers     Member[]
  invitations   Invitation[]
  twoFactors    TwoFactor[]
  ownedContacts Contact[]      @relation("ContactOwner")
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  // Organization plugin extension
  activeOrganizationId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}

model Membership {
  id        String     @id @default(cuid())
  userId    String
  tenantId  String
  role      MemberRole @default(member)
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model TenantSetting {
  id       String @id @default(cuid())
  tenantId String
  key      String
  value    Json

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  diff       Json?
  timestamp  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── Better-Auth: Organizations plugin ───────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members     Member[]
  invitations Invitation[]
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
}

// ─── Better-Auth: Two-factor plugin ──────────────────────────────────────────

model TwoFactor {
  id          String  @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  verified    Boolean? @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── warehouse ────────────────────────────────────────────────────────────────

enum StockMovementType {
  in
  out
}

// ── activities ────────────────────────────────────────────────────────────────

enum ActivityType {
  task
  call
  meeting
  note
}

enum ActivityPriority {
  low
  medium
  high
}

enum ActivityStatus {
  todo
  in_progress
  done
}

// ── crm-pipeline ──────────────────────────────────────────────────────────────

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

// ── timeline (cross-module) ───────────────────────────────────────────────────

enum TimelineEventType {
  lead_stage_changed
  lead_converted
  deal_created
  deal_status_changed
}

// ── notifications ─────────────────────────────────────────────────────────────

enum NotificationType {
  activity_reminder
  deal_won
}

// ── crm-contacts: Contact ─────────────────────────────────────────────────────

model Contact {
  id        String        @id @default(cuid())
  tenantId  String
  type      ContactType   @default(person)
  name      String
  email     String?
  phone     String?
  company   String?
  status    ContactStatus @default(active)
  parentId  String?
  ownerId   String?
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  /// Full-text search vector, maintained by a DB trigger (see migration). Not selectable via Prisma.
  searchable Unsupported("tsvector")?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent         Contact?        @relation("ContactPersons", fields: [parentId], references: [id])
  persons        Contact[]       @relation("ContactPersons")
  owner          User?           @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tags           ContactTag[]
  deals          Deal[]          @relation("DealContact")
  activities     Activity[]      @relation("ContactActivities")
  timelineEvents TimelineEvent[] @relation("ContactTimeline")
  quotes         Quote[]         @relation("QuoteContact")
  workOrders     WorkOrder[]     @relation("WorkOrderContact")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([parentId])
  @@index([ownerId])
  @@map("contacts")
}

// ── crm-contacts: Tag + ContactTag ───────────────────────────────────────────

model Tag {
  id       String @id @default(cuid())
  tenantId String
  name     String

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ── crm-pipeline: PipelineStage, Lead, Deal ───────────────────────────────────

model PipelineStage {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@index([tenantId])
  @@index([tenantId, order])
  @@map("pipeline_stages")
}

model Lead {
  id          String     @id @default(cuid())
  tenantId    String
  title       String
  value       Float      @default(0)
  status      LeadStatus @default(new)
  contactName String?
  stageId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stage  PipelineStage? @relation(fields: [stageId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("leads")
}

model Deal {
  id        String     @id @default(cuid())
  tenantId  String
  title     String
  value     Float      @default(0)
  status    DealStatus @default(open)
  leadId    String?
  contactId String?
  closedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  /// Full-text search vector, maintained by a DB trigger (see migration).
  searchable Unsupported("tsvector")?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact?        @relation("DealContact", fields: [contactId], references: [id], onDelete: SetNull)
  activities     Activity[]      @relation("DealActivities")
  timelineEvents TimelineEvent[] @relation("DealTimeline")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("deals")
}

// ── warehouse: Product, StockMovement ────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  tenantId          String
  sku               String
  name              String
  category          String
  price             Float
  costPrice         Float    @default(0) // costo/prezzo di acquisto → margine = price - costPrice
  imageUrl          String? // foto prodotto (Vercel Blob)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  /// Full-text search vector, maintained by a DB trigger (see migration).
  searchable Unsupported("tsvector")?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  sales          Sale[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model StockMovement {
  id        String            @id @default(cuid())
  tenantId  String
  productId String
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@map("stock_movements")
}

// ── activities: Activity ──────────────────────────────────────────────────────

model Activity {
  id        String           @id @default(cuid())
  tenantId  String
  type      ActivityType     @default(task)
  title     String
  priority  ActivityPriority @default(medium)
  status    ActivityStatus   @default(todo)
  dueDate   DateTime?
  notes     String?
  contactId String?
  dealId    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact? @relation("ContactActivities", fields: [contactId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation("DealActivities", fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, dealId])
  @@map("activities")
}

// ── timeline: TimelineEvent ───────────────────────────────────────────────────

model TimelineEvent {
  id        String            @id @default(cuid())
  tenantId  String
  type      TimelineEventType
  title     String
  fromValue String?
  toValue   String?
  contactId String?
  dealId    String?
  leadId    String?
  createdAt DateTime          @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact? @relation("ContactTimeline", fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation("DealTimeline", fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, dealId])
  @@index([tenantId, leadId])
  @@map("timeline_events")
}

// ── notifications: Notification ───────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  tenantId    String
  recipientId String
  type        NotificationType
  message     String
  link        String?
  dedupeKey   String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([tenantId, recipientId, dedupeKey])
  @@index([tenantId, recipientId, readAt])
  @@map("notifications")
}

// ── quotes: Quote, QuoteLine ──────────────────────────────────────────────────

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id          String      @id @default(cuid())
  tenantId    String
  number      Int // progressivo per tenant
  contactId   String?
  contactName String // snapshot del cliente (resta anche se il contatto cambia/è rimosso)
  status      QuoteStatus @default(draft)
  issueDate   DateTime    @default(now())
  validUntil  DateTime?
  notes       String?
  // Totali calcolati lato server e salvati (per lista/PDF senza ricalcolo)
  subtotal    Float       @default(0) // imponibile (dopo sconti riga)
  taxTotal    Float       @default(0)
  total       Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact    Contact?    @relation("QuoteContact", fields: [contactId], references: [id], onDelete: SetNull)
  lines      QuoteLine[]
  workOrders WorkOrder[] @relation("QuoteWorkOrders")

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quotes")
}

// ── sales: ordini di vendita + margini ────────────────────────────────────────

enum SalesChannel {
  ebay
  amazon
  vinted
  subito
  store
  other
}

model Sale {
  id        String       @id @default(cuid())
  tenantId  String
  productId String
  quantity  Int
  unitPrice Float // prezzo di vendita unitario
  unitCost  Float        @default(0) // snapshot del costo al momento della vendita
  channel   SalesChannel @default(other)
  buyer     String?
  soldAt    DateTime     @default(now())
  createdAt DateTime     @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, soldAt])
  @@index([productId])
  @@map("sales")
}

// ── work-orders: commesse / ordini di lavoro ──────────────────────────────────

enum WorkOrderStatus {
  todo
  in_progress
  done
  delivered
}

model WorkOrder {
  id          String          @id @default(cuid())
  tenantId    String
  number      Int // progressivo per tenant
  title       String
  contactId   String?
  contactName String // snapshot cliente
  quantity    Int?
  dueDate     DateTime?
  status      WorkOrderStatus @default(todo)
  notes       String?
  attachmentUrl  String? // disegno tecnico / allegato (Vercel Blob)
  attachmentName String?
  quoteId     String? // collegamento opzionale al preventivo di origine
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact? @relation("WorkOrderContact", fields: [contactId], references: [id], onDelete: SetNull)
  quote   Quote?   @relation("QuoteWorkOrders", fields: [quoteId], references: [id], onDelete: SetNull)

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("work_orders")
}

model QuoteLine {
  id          String @id @default(cuid())
  tenantId    String
  quoteId     String
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  discountPct Float  @default(0) // % sconto riga
  taxRate     Float  @default(22) // aliquota IVA %
  position    Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote  Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quoteId])
  @@map("quote_lines")
}
