generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TenantPlan {
  starter
  pro
  business
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

// ─── Core multi-tenant models ─────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  plan      TenantPlan   @default(starter)
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships Membership[]
  settings    TenantSetting[]
  auditLogs   AuditLog[]
}

// Skeleton User model — auth fields (password hash, sessions, accounts)
// will be added by Better-Auth in T1.4.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Membership {
  id        String     @id @default(cuid())
  userId    String
  tenantId  String
  role      MemberRole @default(member)
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model TenantSetting {
  id       String @id @default(cuid())
  tenantId String
  key      String
  value    Json

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  diff       Json?
  timestamp  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}
